{
	"name": "@it-service-npm/remark-heading-adjustment",
	"type": "module",
	"version": "1.2.4",
	"description": "This Remark plugin helps to adjust headings depth in markdown file",
	"keywords": [
		"markdown",
		"heading",
		"depth",
		"mdast-plugin",
		"remark-plugin"
	],
	"author": {
		"name": "Sergei S. Betke",
		"email": "Sergey.S.Betke@yandex.ru",
		"url": "https://github.com/sergey-s-betke"
	},
	"homepage": "https://github.com/IT-Service-NPM/remark-heading-adjustment",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/IT-Service-NPM/remark-heading-adjustment.git"
	},
	"bugs": {
		"url": "https://github.com/IT-Service-NPM/remark-heading-adjustment/issues"
	},
	"license": "MIT",
	"engines": {
		"node": ">=22.17"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		"./package.json": "./package.json",
		".": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc --build --clean && tsc --build",
		"CI": "pnpm run build && pnpm run lint && pnpm run test && pnpm run build:readme:API && pnpm run build:readme",
		"check-exports": "attw --pack .",
		"lint": "tsc && eslint",
		"test": "node --import tsx --experimental-test-module-mocks --experimental-test-coverage --test-reporter=spec --test-reporter=junit --test-reporter=lcov --test-reporter-destination=stdout --test-reporter-destination=test/results/junit-report.xml --test-reporter-destination=coverage/lcov.info --test",
		"test:snapshots": "node --import tsx --experimental-test-module-mocks --test-update-snapshots --test",
		"build:readme:API": "api-extractor run --local && npx api-documenter markdown -i ./temp -o ./docs",
		"build:readme:examples": "glob-exec --parallel --foreach \"test/examples/*/readme.mdp\" \"remark {{file}} --output {{file.dir}}/readme.md\"",
		"build:readme:main": "remark .readme.md --output README.md",
		"build:readme": "pnpm run build:readme:examples && pnpm run build:readme:main",
		"build:changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0"
	},
	"packageManager": "pnpm@10.30.3",
	"dependencies": {
		"remark": "^15.0.1",
		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-angular": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"@commitlint/types": "^21.0.1",
		"@eslint/js": "^10.0.1",
		"@it-service-npm/remark-gfm-admonition": "^2.0.0",
		"@it-service-npm/remark-include": "^6.0.6",
		"@it-service-npm/remark-include-code": "^2.3.3",
		"@it-service-npm/remark-relative-url-adjustment": "^1.1.1",
		"@microsoft/api-documenter": "^7.30.5",
		"@microsoft/api-extractor": "^7.58.7",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/mdast": "^4.0.4",
		"@types/node": "^25.9.1",
		"@types/relateurl": "^0.2.33",
		"@typescript-eslint/eslint-plugin": "^8.59.4",
		"@typescript-eslint/parser": "^8.59.4",
		"conventional-changelog": "^7.2.0",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-depend": "^1.5.0",
		"eslint-plugin-n": "^18.0.1",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-sonarjs": "^4.0.3",
		"eslint-plugin-tsdoc": "^0.5.2",
		"eslint-plugin-unicorn": "^64.0.0",
		"glob-exec": "^0.1.1",
		"mdast-util-directive": "^3.1.0",
		"remark-cli": "^12.0.1",
		"remark-code-import": "^1.2.0",
		"remark-directive": "^4.0.0",
		"remark-gfm": "^4.0.1",
		"remark-license": "^6.1.0",
		"remark-lint-code-block-style": "^4.0.1",
		"remark-preset-lint-consistent": "^6.0.1",
		"remark-preset-lint-recommended": "^7.0.1",
		"remark-remove-comments": "^1.1.1",
		"remark-toc": "^9.0.0",
		"remark-typography": "^0.7.3",
		"remark-validate-links": "^13.1.0",
		"to-vfile": "^8.0.0",
		"tsdoc-markdown": "^1.5.0",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.4",
		"unified": "^11.0.5",
		"vfile": "^6.0.3"
	}
}
